---
import Container from "@/components/primitives/Container.astro";
import Link from "@/components/primitives/Link.astro";
import { Icon } from "astro-icon/components";
import { getLocalizedSettings } from "@/lib/localization-helpers";
import { translatePath } from "@/lib/localization-helpers";
import { defaultLocale } from "site";

const currentLocale = Astro.currentLocale;
const { footer, contacts, header } = getLocalizedSettings(currentLocale);
const footerPageLinks = header.pages;
const footerLinkClass =
	"inline-block max-w-full text-white border-b-2 border-white border-solid pb-1 transition-[color,border-color,opacity] duration-200 hover:text-white/70 hover:border-white/70 focus-visible:text-white/70 focus-visible:border-white/70";
---

<div
	class="flex-col text-sm font-medium justify-end pb-10 px-4 lg:px-20 pt-16 flex bg-black"
>
	<Container>
		<div class="items-center flex-col w-full">
			<div class="items-center flex-col justify-center flex text-white">
				<h3
					class="text-4xl lg:text-6xl leading-normal text-center max-w-4xl"
					set:html={footer.title}
				/>
				<div class="mt-8">
					{
						footer?.buttons?.map(({ text, url }) => (
							<Link
								href={url}
								style="buttonLight"
								icon="iconamoon:arrow-top-right-1-thin"
							>
								{text}
							</Link>
						))
					}
				</div>
			</div>
			<div
				class="auto-cols-fr grid-cols-1 lg:grid-cols-[1.8fr_.4fr_1fr] grid-rows-[auto] grid mt-16 gap-10"
			>
				<div class="col-span-1 row-span-1">

					<div class="mt-10">
						<div
							class="auto-cols-fr grid-cols-[1fr_1fr_1fr] grid-rows-[auto] grid gap-[1.88rem]"
						>
							<div class="col-span-1 row-span-1">
								<div
									class="items-start flex-col flex gap-4"
								>
									<ul
										class="text-white/[0.78] text-lg lg:text-xl leading-relaxed list-none"
									>
										{
												footerPageLinks.map(({ title, link }) => (
													<li>
														<a
															href={translatePath(
																currentLocale ?? defaultLocale,
																link,
															)}
															class="transition-opacity duration-200 hover:opacity-70 focus-visible:opacity-70"
														>
															{title}
														</a>
													</li>
												),
											)
										}
									</ul>
								</div>
							</div>

						</div>
					</div>
				</div>
				<div class="col-span-1 row-span-1"></div>
				<div class="col-span-1 row-span-1 text-white">

					<div class="mt-10 text-lg">
						<div class="items-start flex-col flex">
							<a
								class={`${footerLinkClass} mb-3`}
								href={`tel:${contacts.phone}`}
							>
								{contacts.phone}
							</a>
							<a
								class={footerLinkClass}
								href={`mailto:${contacts.mail}`}
							>
								{contacts.mail}
							</a>
						</div>
					</div>

					<div class="mt-10">
						<p class="text-white text-lg font-sans tracking-[0.2em] mb-4">CONNECT</p>
						<div class="flex items-center gap-4">
							<a href="https://www.linkedin.com/in/jaynabergerson/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="text-white hover:opacity-60 transition-opacity">
								<Icon name="mdi:linkedin" class="w-[1.4em] h-[1.4em]" />
							</a>
							<a href="#" target="_blank" rel="noopener noreferrer" aria-label="Medium" class="text-white hover:opacity-60 transition-opacity">
								<Icon name="mdi:medium" class="w-[1.4em] h-[1.4em]" />
							</a>
							<a href="https://github.com/thejaynab" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="text-white hover:opacity-60 transition-opacity">
								<Icon name="mdi:github" class="w-[1.4em] h-[1.4em]" />
							</a>
							<a href="mailto:hello@jaynabergerson.com" aria-label="Email" class="text-white hover:opacity-60 transition-opacity">
								<Icon name="mdi:email-outline" class="w-[1.4em] h-[1.4em]" />
							</a>
						</div>
					</div>
				</div>
			</div>
			<div class="mt-16">
				<div class="items-center justify-between flex gap-4">
					<p class="text-white/[0.78] text-base">
						{footer.copyright}
					</p>

					<div class="flex gap-5 text-lg">
						<a href="/privacy" class={footerLinkClass}>Privacy policy</a>
						<a href="/terms" class={footerLinkClass}>Terms</a>
					</div>
				</div>
			</div>
		</div>
	</Container>
</div>

<slot />
