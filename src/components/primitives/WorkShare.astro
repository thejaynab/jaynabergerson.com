---
import Link from "@/components/primitives/Link.astro";
import { Icon } from "astro-icon/components";
---

<div class="relative z-10 flex h-auto w-auto flex-wrap items-center justify-end gap-4">
	<div class="flex flex-wrap items-center gap-4">
		<Link
			class="flex justify-center gap-3"
			href="https://medium.com/"
			size="md"
			style="outline"
		>
			<Icon size={23} name="mdi:medium" />
			<span class="hidden sm:inline-block">Follow</span>
		</Link>

		<Link
			class="flex justify-center gap-3"
                        href="mailto:hello@jaynabergerson.com"
                        size="md"
                        style="outline"
                >
                        <Icon size={23} name="mdi:email-outline" />

		<Link class="flex justify-center gap-3" href="#top" size="md" style="outline">
			<Icon size={23} name="ic:sharp-vertical-align-top" />
			<span class="hidden sm:inline-block">Return to Top</span>
		</Link>
	</div>
</div>
