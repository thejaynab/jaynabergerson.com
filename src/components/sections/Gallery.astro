---
import { Image } from "astro:assets";

interface Props {
	folder: string;
	exclude?: string;
	layout?: string;
	alts?: string;
}

const { folder, exclude, layout, alts } = Astro.props;
const gridClass = layout ? `gallery-grid gallery-grid--${layout}` : "gallery-grid";
const altList = alts ? alts.split("|").map((s: string) => s.trim()) : [];

// Import all post and work images eagerly
const allImages = import.meta.glob<{ default: ImageMetadata }>(
	["/src/assets/posts/**/*.{webp,png,jpg,jpeg,svg,gif}", "/src/assets/works/**/*.{webp,png,jpg,jpeg,svg,gif}"],
	{ eager: true }
);

// Filter to only images in the specified folder, excluding any specified filenames
const excludeList = exclude ? exclude.split(",").map((s: string) => s.trim()) : [];

const images = Object.entries(allImages)
	.filter(([path]) => path.includes(`/${folder}/`))
	.filter(([path]) => !excludeList.some((ex: string) => path.includes(ex)))
	.sort(([a], [b]) => a.localeCompare(b))
	.map(([path, mod], i) => ({
		src: mod.default,
		alt: altList[i] || path.split("/").pop()?.replace(/\.[^.]+$/, "").replace(/-/g, " ") || "",
	}));

// Skip rendering if no images found for this folder
if (images.length === 0) return;
---

{
	(layout === 'feature-left' || layout === 'feature-left-wide') ? (
		<div class={gridClass}>
			<div class="gallery-item gallery-item--feature">
				<Image
					src={images[0].src}
					alt={images[0].alt}
					widths={[400, 600, 800]}
					sizes="(max-width: 640px) 100vw, 66vw"
					class="gallery-image"
				/>
			</div>
			<div class="gallery-stack">
				{images.slice(1).map((img) => (
					<div class="gallery-item">
						<Image
							src={img.src}
							alt={img.alt}
							widths={[400, 600, 800]}
							sizes="(max-width: 640px) 100vw, 33vw"
							class="gallery-image"
						/>
					</div>
				))}
			</div>
		</div>
	) : layout === 'feature-right' ? (
		<div class={gridClass}>
			<div class="gallery-stack">
				{images.slice(0, -1).map((img) => (
					<div class="gallery-item">
						<Image
							src={img.src}
							alt={img.alt}
							widths={[400, 600, 800]}
							sizes="(max-width: 640px) 100vw, 33vw"
							class="gallery-image"
						/>
					</div>
				))}
			</div>
			<div class="gallery-item gallery-item--feature">
				<Image
					src={images[images.length - 1].src}
					alt={images[images.length - 1].alt}
					widths={[400, 600, 800]}
					sizes="(max-width: 640px) 100vw, 66vw"
					class="gallery-image"
				/>
			</div>
		</div>
	) : (
		<div class={gridClass}>
			{images.map((img) => (
				<div class="gallery-item">
					<Image
						src={img.src}
						alt={img.alt}
						widths={[400, 600, 800]}
						sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
						class="gallery-image"
					/>
				</div>
			))}
		</div>
	)
}

<style>
	.gallery-grid {
		columns: 1;
		column-gap: 10px;
		margin: 2rem 0;
	}

	@media (min-width: 640px) {
		.gallery-grid {
			columns: 2;
		}
	}

	@media (min-width: 1024px) {
		.gallery-grid {
			columns: 3;
		}
	}

	.gallery-item {
		break-inside: avoid;
		margin-bottom: 10px;
	}

	.gallery-image {
		width: 100%;
		height: auto;
		display: block;
		border-radius: 8px;
	}

	/* --- Layout variants --- */

	/* 1-column */
	.gallery-grid--1-col {
		columns: 1 !important;
	}

	/* 2-column */
	.gallery-grid--2-col {
		columns: 1 !important;
	}
	@media (min-width: 640px) {
		.gallery-grid--2-col {
			columns: 2 !important;
		}
	}

	/* 3-column (same as default but explicit) */
	.gallery-grid--3-col {
		columns: 1 !important;
	}
	@media (min-width: 640px) {
		.gallery-grid--3-col {
			columns: 2 !important;
		}
	}
	@media (min-width: 1024px) {
		.gallery-grid--3-col {
			columns: 3 !important;
		}
	}

	/* 4-column */
	.gallery-grid--4-col {
		columns: 1 !important;
	}
	@media (min-width: 640px) {
		.gallery-grid--4-col {
			columns: 2 !important;
		}
	}
	@media (min-width: 1024px) {
		.gallery-grid--4-col {
			columns: 4 !important;
		}
	}

	/* Feature-left: tall image left, stacked right */
	.gallery-grid--feature-left,
	.gallery-grid--feature-right,
	.gallery-grid--feature-left-wide {
		columns: unset !important;
		display: grid;
		grid-template-columns: 1fr;
		gap: 10px;
	}

	.gallery-stack {
		display: flex;
		flex-direction: column;
		gap: 10px;
	}

	@media (min-width: 640px) {
		.gallery-grid--feature-left {
			grid-template-columns: 1fr 1fr;
		}
		.gallery-grid--feature-right {
			grid-template-columns: 1fr 1fr;
		}
		.gallery-grid--feature-left-wide {
			grid-template-columns: 2fr 1fr;
		}
	}
</style>
