---
interface TLDRItem {
	label: string;
	value: string;
}

interface Props {
	items: TLDRItem[];
}

const { items } = Astro.props;
---

<div class="work-tldr">
	{items.map(({ label, value }, i) => (
		<div class:list={["work-tldr-row", { "work-tldr-row--border": i > 0 }]}>
			<span class="work-tldr-label">{label}</span>
			<span class="work-tldr-value">{value}</span>
		</div>
	))}
</div>

<style>
	.work-tldr {
		display: flex;
		flex-direction: column;
		padding: 1.25rem 0;
		border-radius: 0.75rem;
		position: relative;
		z-index: 1;
	}

	.work-tldr-row {
		display: flex;
		align-items: baseline;
		padding: 0.65rem 0;
		gap: 2rem;
	}

	.work-tldr-row--border {
		border-top: 1px solid rgba(0, 0, 0, 0.12);
	}

	.work-tldr-label {
		font-family: "Roboto Mono", "Lucida Console", Monaco, monospace;
		font-size: 12px;
		font-weight: 500;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: rgba(0, 0, 0, 0.4);
		flex-shrink: 0;
		width: 5.5rem;
	}

	.work-tldr-value {
		font-family: "Inter Tight", Arial, Helvetica, sans-serif;
		font-size: 0.95rem;
		font-weight: 500;
		letter-spacing: 0.01em;
		color: rgb(40, 40, 40);
		text-align: left;
	}
</style>
