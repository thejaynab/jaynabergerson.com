---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import Container from "@/components/primitives/Container.astro";
import Link from "@/components/primitives/Link.astro";
import Prose from "@/components/primitives/Prose.astro";
import WorkShare from "@/components/primitives/WorkShare.astro";
import WorkTLDR from "@/components/sections/WorkTLDR.astro";
import { loadVideo } from "@/lib/asset-helpers";
import { Icon } from "astro-icon/components";
import { defaultLocale } from "site";
import BaseLayout from "./BaseLayout.astro";

type Props = {
	frontmatter: CollectionEntry<"works">;
};

const currentLocale = Astro.currentLocale;

interface WorkLayoutLocale {
	visitProject: string;
}

interface ComponentLocales {
	[key: string]: WorkLayoutLocale;
}

const componentLocales: ComponentLocales = {
	it: {
		visitProject: "Visita progetto",
	},
	en: {
		visitProject: "Visit project",
	},
};

const l = componentLocales[currentLocale ?? defaultLocale];

const { frontmatter } = Astro.props;

const videoSrc = frontmatter.data?.video
	? await loadVideo(frontmatter.data.video)
	: null;
---

<BaseLayout>
	<section class="work-layout py-32 md:py-56">
		<Container>
			{/* Work Type Category — centered */}
			{
				frontmatter.data.workType && (
					<div class="work-header-meta">
						<span class="work-type-badge">
							{frontmatter.data.workType}
						</span>
					</div>
				)
			}

			{/* Title — centered */}
			<h1 class="work-title">{frontmatter.data.title}</h1>

			{/* Tech Category — centered */}
			{
				frontmatter.data.tech && (
					<div class="work-tech">
						{frontmatter.data.tech}
					</div>
				)
			}

			{/* Description + intro — above columns, centered */}
			<div class="work-description-block">
				<div class="work-description" set:html={frontmatter.data?.description} />
				{
					frontmatter.data.intro && (
						<div class="work-intro-paragraph">
							{frontmatter.data.intro}
						</div>
					)
				}
			</div>

			{/* Three-column: TLDR | featured image | impact */}
			<div class="work-intro-grid">
				<div class="work-intro-text">
					{
						frontmatter.data.link && (
							<Link
								href={frontmatter.data.link}
								target="_blank"
								class="mt-6"
								style="outline"
							>
								{l.visitProject}
								<Icon
									name="iconamoon:arrow-top-right-1-thin"
									class="inline-block w-6 h-6 ml-2"
								/>
							</Link>
						)
					}
					{
						frontmatter.data.tldr && frontmatter.data.tldr.length > 0 && (
							<WorkTLDR items={frontmatter.data.tldr} />
						)
					}
				</div>
				<div class="work-intro-cover">
					{
						"video" in frontmatter.data &&
						frontmatter.data?.video &&
						videoSrc ? (
							<video autoplay loop muted playsinline class="w-full rounded-3xl">
								<source src={videoSrc} />
								Your browser does not support the video tag.
							</video>
						) : (
							"cover" in frontmatter.data &&
							frontmatter.data?.cover && (
								<Image
									class="w-full rounded-3xl"
									src={frontmatter.data?.cover}
									alt={`Cover image for ${frontmatter.data?.title}`}
								/>
							)
						)
					}
				</div>
				{
					frontmatter.data.impact && frontmatter.data.impact.length > 0 && (
						<div class="work-intro-impact">
							<span class="work-impact-title">Impact</span>
							<div class="work-impact-rows">
								{frontmatter.data.impact.map(({ value, description }: { value: string; description: string }) => (
									<div class="work-impact-row">
										<span class="work-impact-number">{value}</span>
										<span class="work-impact-desc">{description}</span>
									</div>
								))}
							</div>
							<div class="work-impact-button">
								<Link
									href="#what-changed"
									size="md"
									style="outline"
									class="work-impact-link flex justify-center gap-3"
								>
									<Icon size={23} name="ic:sharp-vertical-align-bottom" />
									<span>View full impact</span>
								</Link>
							</div>
						</div>
					)
				}
			</div>

			{/* Full-width hero image below intro */}
			{
				frontmatter.data.heroImage && (
					<div class="work-hero-image">
						<Image
							class="w-full rounded-3xl"
							src={frontmatter.data.heroImage}
							alt={`Hero image for ${frontmatter.data?.title}`}
						/>
					</div>
				)
			}

			{/* Body content */}
			<div class="flex w-full flex-col items-center justify-center pt-10">
				<Prose class="work-prose"><slot /></Prose>
				<div class="mx-auto w-full max-w-3xl pt-20">
					<WorkShare />
				</div>
			</div>
		</Container>
	</section>
</BaseLayout>

<style is:global>
	/* Case study–scoped typography — translated from PostLayout article styles.
	   Uses is:global so child-component markup is reached.
	   All selectors are prefixed with .work-* so they won't leak. */

	/* Work Type Badge — matches article category style */
	.work-type-badge {
		font-family: "Inter Tight", Arial, Helvetica, sans-serif;
		font-size: 13px;
		font-weight: 600;
		letter-spacing: 0.04em;
		line-height: 1;
		padding: 8px 24px;
		text-transform: uppercase;
		display: inline-block;
		border: 2px solid black;
		border-radius: 9999px;
		color: inherit;
		text-decoration: none;
	}

	.work-header-meta {
		text-align: center;
		padding-bottom: 1rem;
	}

	.work-title {
		font-family: "Inter Tight", Arial, Helvetica, sans-serif;
		font-size: 72px;
		font-style: normal;
		font-weight: 600;
		letter-spacing: -1.44px;
		line-height: 70px;
		text-align: center;
	}

	/* Tech line — matches article author style */
	.work-tech {
		font-family: "Roboto Mono", "Lucida Console", Monaco, monospace;
		font-size: 1rem;
		font-style: normal;
		font-weight: 500;
		letter-spacing: 0.03rem;
		text-transform: uppercase;
		padding-top: 1.25rem;
		text-align: center;
	}

	/* Description block — above columns, centered */
	.work-description-block {
		max-width: 48rem;
		margin-left: auto;
		margin-right: auto;
		margin-top: 2.5rem;
	}

	/* Three-column intro grid */
	.work-intro-grid {
		display: grid;
		grid-template-columns: 1fr;
		gap: 2.5rem;
		margin-top: 40px;
		align-items: start;
		background: white;
		padding: 2rem;
		border-radius: 1rem;
		box-shadow: 0 0 30px 15px white;
		position: relative;
		z-index: 1;
	}

	@media (min-width: 768px) {
		.work-intro-grid {
			grid-template-columns: 1fr 1fr;
			gap: 2rem;
		}
	}

	@media (min-width: 1024px) {
		.work-intro-grid {
			grid-template-columns: 1fr 1fr 1fr;
			gap: 2.5rem;
		}
	}

	.work-intro-text {
		display: flex;
		flex-direction: column;
		justify-content: flex-start;
	}

	.work-intro-cover {
		display: flex;
		align-items: flex-start;
		justify-content: center;
	}

	.work-intro-cover img,
	.work-intro-cover video {
		width: 100%;
		height: auto;
		border-radius: 1.5rem;
		object-fit: cover;
	}

	/* Impact column */
	.work-intro-impact {
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
		padding: 1.25rem 0;
	}

	.work-impact-title {
		font-family: 'Roboto Mono', monospace;
		font-size: 12px;
		font-weight: 500;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		color: rgba(0, 0, 0, 0.4);
	}

	.work-impact-rows {
		display: flex;
		flex-direction: column;
		gap: 0;
	}

	.work-impact-row {
		display: flex;
		align-items: center;
		gap: 1rem;
		text-align: left;
		padding: 1rem 0;
	}

	.work-impact-row + .work-impact-row {
		border-top: 1px solid rgba(0, 0, 0, 0.1);
	}

	.work-impact-number {
		font-family: 'Inter Tight', sans-serif;
		font-size: 2.5rem;
		font-weight: 600;
		line-height: 1;
		color: rgba(0, 0, 0, 0.7);
		width: 4.5rem;
		flex-shrink: 0;
		text-align: left;
	}

	.work-impact-desc {
		font-family: 'Inter Tight', sans-serif;
		font-size: 0.95rem;
		font-weight: 400;
		line-height: 1.4;
		color: rgba(0, 0, 0, 0.6);
	}

	.work-impact-button {
		margin-top: 0.5rem;
	}

	.work-impact-link {
		font-size: 0.85rem !important;
		color: rgb(63, 63, 63) !important;
		text-decoration: none !important;
		padding: 7px 14px !important;
	}

	/* TLDR section — full width, centered */
	.work-tldr-section {
		max-width: 48rem;
		margin-left: auto;
		margin-right: auto;
		margin-top: 1rem;
	}

	/* Full-width hero image below TLDR */
	.work-hero-image {
		margin-top: 2.5rem;
		max-height: 600px;
		overflow: hidden;
		border-radius: 1.5rem;
		position: relative;
	}

	.work-hero-image img {
		width: 100%;
		position: absolute;
		bottom: 0;
		left: 0;
	}

	.work-description {
		font-family: "Inter Tight", Arial, Helvetica, sans-serif !important;
		font-size: 1.5rem !important;
		font-style: normal !important;
		font-weight: 400 !important;
		letter-spacing: 0.03rem !important;
		line-height: 2.1rem !important;
		text-align: left !important;
		width: 100% !important;
		color: rgb(63, 63, 63) !important;
	}

	.work-intro-paragraph {
		font-family: "Inter Tight", Arial, Helvetica, sans-serif;
		font-size: 1.5rem;
		font-style: normal;
		font-weight: 600;
		letter-spacing: 0.03rem;
		line-height: 2.1rem;
		text-align: left;
		width: 100%;
		color: rgb(63, 63, 63);
		margin-top: 1.5rem;
	}

	/* Case study H2 */
	.work-prose h2 {
		font-family: "Inter Tight", Arial, Helvetica, sans-serif !important;
		font-size: 2.6rem !important;
		font-style: normal !important;
		font-weight: 600 !important;
		letter-spacing: 0.03rem !important;
		line-height: 2.8rem !important;
		margin-top: 2.5rem !important;
		margin-bottom: 1.25rem !important;
	}

	/* Case study H3 */
	.work-prose h3 {
		letter-spacing: 0.03rem !important;
		margin-top: 40px !important;
		margin-block-end: 20px !important;
		margin-bottom: 20px !important;
		margin-block-start: 40px !important;
	}

	/* Case study H4 */
	.work-prose h4 {
		letter-spacing: 0.03rem !important;
	}

	/* Case study paragraphs */
	.work-prose p {
		font-family: "Inter Tight", Arial, Helvetica, sans-serif !important;
		font-size: 1.3rem !important;
		font-style: normal !important;
		font-weight: 400 !important;
		letter-spacing: 0.03rem !important;
		line-height: 1.8rem !important;
		color: rgb(63, 63, 63) !important;
		margin-block-end: 20px !important;
		margin-bottom: 20px !important;
		margin-block-start: 0px !important;
	}

	/* Case study list items — match paragraph styling */
	.work-prose li {
		font-family: "Inter Tight", Arial, Helvetica, sans-serif !important;
		font-size: 1.3rem !important;
		font-style: normal !important;
		font-weight: 400 !important;
		letter-spacing: 0.03rem !important;
		line-height: 1.8rem !important;
		color: rgb(63, 63, 63) !important;
	}

	/* Case study unordered/ordered lists */
	.work-prose ul,
	.work-prose ol {
		font-family: "Inter Tight", Arial, Helvetica, sans-serif !important;
		font-size: 1.3rem !important;
		letter-spacing: 0.03rem !important;
		line-height: 1.8rem !important;
		color: rgb(63, 63, 63) !important;
	}

	/* Responsive title scaling */
	@media (max-width: 1024px) {
		.work-title {
			font-size: 52px;
			line-height: 52px;
			letter-spacing: -1.04px;
		}

		.work-prose h2 {
			font-size: 2.5rem !important;
			line-height: 1.1 !important;
		}
	}

	@media (max-width: 640px) {
		.work-title {
			font-size: 36px;
			line-height: 38px;
			letter-spacing: -0.72px;
		}

		.work-prose h2 {
			font-size: 2rem !important;
			line-height: 1.1 !important;
		}
	}

	/* Gallery breakout — match featured image width while text stays at prose width */
	.work-prose {
		max-width: 100% !important;
	}

	/* Constrain text elements to readable width and center them */
	.work-prose h2,
	.work-prose h3,
	.work-prose p,
	.work-prose ul,
	.work-prose ol,
	.work-prose blockquote {
		max-width: 48rem !important;
		margin-left: auto !important;
		margin-right: auto !important;
	}

	/* Remove prose margins from gallery images */
	.work-prose .gallery-grid img {
		margin-top: 0 !important;
		margin-bottom: 0 !important;
	}
</style>
