---
interface Props {
	content: string;
	language?: string;
}

const { content, language } = Astro.props;
---

<div class="code-block-wrapper">
	<pre><code>{content}</code></pre>
	<div class="code-footer flex items-center justify-between bg-white rounded-lg mx-2 mb-2 px-4 py-3">
		<button
			class="copy-prompt-btn flex items-center gap-1.5 bg-transparent px-0 py-0 text-sm text-slate-500 transition-all hover:text-slate-900 cursor-pointer border-none"
			data-code={content}
			type="button"
		>
			<svg class="copy-icon w-4 h-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75" />
			</svg>
			<svg class="check-icon w-4 h-4 hidden" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
				<path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
			</svg>
			<span class="copy-label">Copy Prompt</span>
		</button>
		{language && (
			<span class="text-sm text-slate-500">AI Generator: {language.charAt(0).toUpperCase() + language.slice(1)}</span>
		)}
	</div>
</div>

<style>
	.code-block-wrapper {
		background: #f5f5f5;
		border-radius: 10px;
		overflow: hidden;
		max-width: 100%;
		margin-bottom: 2rem;
	}
	.code-block-wrapper pre {
		background: transparent !important;
		margin: 0 !important;
		border-radius: 0 !important;
		max-width: 100% !important;
	}
</style>

<script>
	document.querySelectorAll('.copy-prompt-btn').forEach((btn) => {
		btn.addEventListener('click', async () => {
			const code = btn.getAttribute('data-code') || '';
			await navigator.clipboard.writeText(code);

			const copyIcon = btn.querySelector('.copy-icon') as HTMLElement;
			const checkIcon = btn.querySelector('.check-icon') as HTMLElement;
			const label = btn.querySelector('.copy-label') as HTMLElement;

			copyIcon.classList.add('hidden');
			checkIcon.classList.remove('hidden');
			label.textContent = 'Copied!';

			setTimeout(() => {
				copyIcon.classList.remove('hidden');
				checkIcon.classList.add('hidden');
				label.textContent = 'Copy Prompt';
			}, 2000);
		});
	});
</script>
