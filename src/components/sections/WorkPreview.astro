---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import { loadVideo } from "@/lib/asset-helpers";
import { translatePath, unlocalizedUrl } from "@/lib/localization-helpers";
import { Icon } from "astro-icon/components";
import { defaultLocale } from "site";

const currentLocale = Astro.currentLocale;

interface Props {
	work: CollectionEntry<"works">;
}

const { work } = Astro.props;

const unlocalizedPath = unlocalizedUrl(work.slug);
const localizedPath = translatePath(
	currentLocale ?? defaultLocale,
	`/work${unlocalizedPath}`,
);

const videoSrc = work.data?.video ? await loadVideo(work.data.video) : null;
---

<a
	href={localizedPath}
	class="work-card group block overflow-hidden relative cursor-pointer"
	style={!work.data.cover && work.data.backgroundColor ? `background-color: ${work.data.backgroundColor}` : undefined}
>
	<!-- Background image — fills entire card (only if cover image provided) -->
	{work.data.cover && (
		<div class="absolute inset-0 z-0">
			{
				videoSrc ? (
					<video
						class="work-media w-full h-full object-cover"
						autoplay
						loop
						muted
						playsinline
					>
						<source src={videoSrc} />
					</video>
				) : (
					<Image
						src={work.data.cover}
						alt={`Cover for ${work.data.title}`}
						class="work-media w-full h-full object-cover"
					/>
				)
			}
		</div>
	)}

	<!-- Arrow icon — fades in on hover -->
	<div class="hover-icon absolute top-10 right-10 z-20">
		<div
			class="bg-white rounded-full w-10 h-10 flex items-center justify-center"
		>
			<Icon
				name="iconamoon:arrow-top-right-1-thin"
				class="w-6 h-6 text-black"
			/>
		</div>
	</div>

	<!-- Text overlay -->
	<div class="relative z-10 flex flex-col justify-between h-full p-10">
		<div>
			<!-- Category / Tags -->
			<p class:list={[
				"text-[0.8125rem] font-bold tracking-wide mb-4",
				work.data.cover ? "text-neutral-800" : "text-white/80"
			]}>
				{Array.from(work.data.tags).join(" \u00b7 ")}
			</p>

			<!-- Title -->
			<h3 class:list={[
				"text-[2.5rem] md:text-[3rem] font-extrabold leading-[1.05] mb-3 pr-16",
				work.data.cover ? "text-black" : "text-white"
			]}>
				{work.data.title}
			</h3>

			<!-- Description -->
			{work.data.description && (
				<p class:list={[
					"text-[1rem] md:text-[1.0625rem] leading-relaxed max-w-[75%]",
					work.data.cover ? "text-neutral-700" : "text-white/70"
				]}>
					{work.data.description}
				</p>
			)}
		</div>
	</div>
</a>

<style>
	/* Base Card */
	.work-card {
		aspect-ratio: 3 / 4;
		border-radius: 12px;
		box-shadow: none;
		transition: all 0.45s cubic-bezier(0.165, 0.84, 0.44, 1);
	}

	/* Lift Up + Slight Enlarge on Hover */
	.work-card:hover {
		transform: translateY(-12px) scale(1.01);
		box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.1);
	}

	/* Arrow Icon — Opacity Fade */
	.hover-icon {
		opacity: 0;
		transition: opacity 0.3s ease;
	}

	.work-card:hover .hover-icon {
		opacity: 1;
	}

	/* Image Zoom */
	.work-media {
		transition: transform 0.6s ease;
	}

	.work-card:hover .work-media {
		transform: scale(1.05);
	}
</style>
