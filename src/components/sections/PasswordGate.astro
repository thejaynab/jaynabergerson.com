---
/**
 * PasswordGate — wraps case study content behind a client-side password wall.
 *
 * Usage in .mdoc:
 *   {% PasswordGate %}
 *   Protected content here…
 *   {% /PasswordGate %}
 *
 * - Single shared password across all case studies (hash stored below).
 * - Global unlock via localStorage + CustomEvent.
 * - Inline blur wall with frosted overlay.
 */
---

<div
	class="password-gate"
	x-data={`{
		locked: true,
		password: '',
		error: false,
		HASH: 'cf3c8618814ccdc0a2d74e310827213012316c695a4e26fa4ef49c947e388e6e',
		STORAGE_KEY: 'portfolio_unlocked',
		EVENT_NAME: 'portfolio-unlocked',

		init() {
			if (localStorage.getItem(this.STORAGE_KEY) === 'true') {
				this.locked = false;
			}
			window.addEventListener(this.EVENT_NAME, () => {
				this.locked = false;
			});
		},

		async submit() {
			this.error = false;
			const encoded = new TextEncoder().encode(this.password);
			const hashBuffer = await crypto.subtle.digest('SHA-256', encoded);
			const hashArray = Array.from(new Uint8Array(hashBuffer));
			const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
			if (hashHex === this.HASH) {
				this.locked = false;
				localStorage.setItem(this.STORAGE_KEY, 'true');
				window.dispatchEvent(new CustomEvent(this.EVENT_NAME));
			} else {
				this.error = true;
				this.password = '';
			}
		}
	}`}
>
	<!-- Locked state: blurred preview + overlay -->
	<div x-show="locked" class="gate-locked">
		<div class="gate-preview" aria-hidden="true">
			<slot />
		</div>
		<div class="gate-overlay">
			<div class="gate-prompt">
				<svg class="gate-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
					<rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
					<path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
				</svg>
				<p class="gate-title">This section is password-protected</p>
				<p class="gate-subtitle">Enter the password to view the full case study</p>
				<form
					class="gate-form"
					x-on:submit.prevent="submit()"
				>
					<input
						type="password"
						x-model="password"
						placeholder="Enter password"
						class="gate-input"
						autocomplete="off"
					/>
					<button type="submit" class="gate-button">Unlock</button>
				</form>
				<p x-show="error" x-transition class="gate-error">Incorrect password. Please try again.</p>
			</div>
		</div>
	</div>

	<!-- Unlocked state: full content -->
	<div x-show="!locked" x-transition:enter="transition ease-out duration-500" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100">
		<slot />
	</div>
</div>

<style>
	.password-gate {
		position: relative;
	}

	/* Locked container */
	.gate-locked {
		position: relative;
		overflow: hidden;
		max-height: 300px;
		border-radius: 1rem;
	}

	/* Blurred preview of content behind */
	.gate-preview {
		filter: blur(8px);
		-webkit-filter: blur(8px);
		pointer-events: none;
		user-select: none;
		opacity: 0.5;
	}

	/* Frosted overlay */
	.gate-overlay {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(
			to bottom,
			rgba(255, 255, 255, 0.3) 0%,
			rgba(255, 255, 255, 0.85) 40%,
			rgba(255, 255, 255, 0.95) 100%
		);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		z-index: 10;
	}

	/* Prompt card */
	.gate-prompt {
		text-align: center;
		max-width: 360px;
		padding: 2rem;
	}

	.gate-icon {
		width: 32px;
		height: 32px;
		margin: 0 auto 1rem;
		color: rgba(0, 0, 0, 0.35);
	}

	.gate-title {
		font-family: 'Inter Tight', Arial, Helvetica, sans-serif;
		font-size: 1.1rem;
		font-weight: 600;
		color: rgb(30, 30, 30);
		margin: 0 0 0.35rem;
		line-height: 1.3;
	}

	.gate-subtitle {
		font-family: 'Inter Tight', Arial, Helvetica, sans-serif;
		font-size: 0.9rem;
		font-weight: 400;
		color: rgba(0, 0, 0, 0.5);
		margin: 0 0 1.25rem;
		line-height: 1.4;
	}

	.gate-form {
		display: flex;
		gap: 0.5rem;
		justify-content: center;
	}

	.gate-input {
		font-family: 'Inter Tight', Arial, Helvetica, sans-serif;
		font-size: 0.9rem;
		padding: 8px 14px;
		border: 1px solid rgba(0, 0, 0, 0.15);
		border-radius: 6px;
		outline: none;
		width: 180px;
		transition: border-color 0.2s;
	}

	.gate-input:focus {
		border-color: rgba(0, 0, 0, 0.4);
	}

	.gate-button {
		font-family: 'Inter Tight', Arial, Helvetica, sans-serif;
		font-size: 0.85rem;
		font-weight: 600;
		padding: 8px 18px;
		background: #000;
		color: #fff;
		border: none;
		border-radius: 6px;
		cursor: pointer;
		transition: background 0.2s;
	}

	.gate-button:hover {
		background: #222;
	}

	.gate-error {
		font-family: 'Inter Tight', Arial, Helvetica, sans-serif;
		font-size: 0.8rem;
		color: #c0392b;
		margin: 0.75rem 0 0;
	}
</style>
