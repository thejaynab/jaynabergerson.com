---
import { Image } from "astro:assets";
import { type CollectionEntry, getCollection } from "astro:content";
import { translatePath, unlocalizedUrl } from "@/lib/localization-helpers";
import { Icon } from "astro-icon/components";
import { defaultLocale } from "site";

const currentLocale = Astro.currentLocale;

interface Props {
	currentSlug: string;
	currentCategory: string;
}

const { currentSlug, currentCategory } = Astro.props;

const allPosts = await getCollection("articles");

// Exclude current article and hidden posts
const otherPosts = allPosts
	.filter((post) => post.slug !== currentSlug && !post.data.hidden)
	.map((post) => ({
		...post,
		slug: post.slug.startsWith("/") ? post.slug : `/${post.slug}`,
	}));

// Same-category posts first (sorted by lastUpdateDate desc), then others (sorted by lastUpdateDate desc)
const sameCategoryPosts = otherPosts
	.filter((post) => post.data.category === currentCategory)
	.sort((a, b) => b.data.lastUpdateDate.getTime() - a.data.lastUpdateDate.getTime());

const otherCategoryPosts = otherPosts
	.filter((post) => post.data.category !== currentCategory)
	.sort((a, b) => b.data.lastUpdateDate.getTime() - a.data.lastUpdateDate.getTime());

const relatedPosts = [...sameCategoryPosts, ...otherCategoryPosts].slice(0, 6) as CollectionEntry<"articles">[];
---

{relatedPosts.length > 0 && (
	<div class="dont-miss-section">
		<div class="dont-miss-container">
			<h2 class="dont-miss-heading">Don't miss</h2>
			<div class="dont-miss-grid grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-[10px]">
				{relatedPosts.map((post) => {
					const unlocalizedPath = unlocalizedUrl(post.slug);
					const localizedPath = translatePath(
						currentLocale ?? defaultLocale,
						`/post${unlocalizedPath}`,
					);
					return (
						<a href={localizedPath} class="dont-miss-card group">
							<div class="dont-miss-card-body">
								<span class="dont-miss-card-category">
									{post.data.category}
								</span>
							<span class="dont-miss-card-title" set:html={post.data.title} />
								<span class="dont-miss-card-date">
									{post.data.pubDate.toLocaleDateString("en-US", {
										month: "long",
										day: "numeric",
										year: "numeric",
										timeZone: "UTC",
									})}
								</span>
							</div>
							<div class="dont-miss-card-image-wrapper">
								<div class="dont-miss-card-arrow">
									<div class="dont-miss-card-arrow-inner">
										<Icon
											name="iconamoon:arrow-top-right-1-thin"
											class="w-12 h-12"
										/>
									</div>
								</div>
								<Image
									src={post.data.cover}
									alt={post.data.title}
									class="w-full h-full object-cover rounded-xl"
								/>
							</div>
						</a>
					);
				})}
			</div>
		</div>
	</div>
)}

<style>
	.dont-miss-section {
		background-color: #e7e7e7;
		padding: 10px 5% 0px;
		margin-top: 4rem;
	}

	.dont-miss-container {
		max-width: 90rem;
		margin-left: auto;
		margin-right: auto;
		padding-top: 6%;
		padding-bottom: 12%;
	}

	.dont-miss-heading {
		font-size: 4rem;
		font-weight: 600;
		letter-spacing: -0.96px;
		margin-bottom: 2.5rem;
	}

	.dont-miss-card {
		background: #fff;
		border-radius: 1rem;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		text-decoration: none;
		color: inherit;
		transition: transform 0.3s ease, box-shadow 0.3s ease;
	}

	.dont-miss-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
	}

	.dont-miss-card-image-wrapper {
		position: relative;
		padding: 0 20px 20px;
		overflow: hidden;
	}

	.dont-miss-card-image-wrapper :global(img) {
		aspect-ratio: 16 / 10;
		transition: transform 0.3s ease;
	}

	.dont-miss-card:hover .dont-miss-card-image-wrapper :global(img) {
		transform: scale(1.04);
	}

	.dont-miss-card-arrow {
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		z-index: 10;
		width: 1rem;
		height: 1rem;
		opacity: 0;
		transition: all 0.3s ease;
		display: flex;
		align-items: center;
		justify-content: center;
	}

	.dont-miss-card:hover .dont-miss-card-arrow {
		width: 5rem;
		height: 5rem;
		opacity: 1;
	}

	.dont-miss-card-arrow-inner {
		background: rgba(255, 255, 255, 0.75);
		backdrop-filter: blur(5px);
		border-radius: 9999px;
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		color: #000;
	}

	.dont-miss-card-body {
		padding: 20px;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.dont-miss-card-category {
		font-size: 0.75rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.05em;
		border: 2px solid #000;
		border-radius: 1.5rem;
		padding: 0.25rem 1rem 0.15rem;
		display: inline-block;
		width: fit-content;
	}

	.dont-miss-card-title {
		font-size: 2rem;
		font-weight: 600;
		line-height: 1.15;
		margin-top: 0.25rem;
	}

	.dont-miss-card-date {
		font-family: "Roboto Mono", "Lucida Console", Monaco, monospace;
		font-size: 13px;
		font-weight: 500;
		letter-spacing: 0.6px;
		opacity: 0.7;
		margin-top: 0.25rem;
	}
</style>
