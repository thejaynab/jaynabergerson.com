---
import { Image } from "astro:assets";
import defaultImage from "@/assets/pages/about/about.png";

interface Props {
	image?: string;
}

const { image } = Astro.props;

const allImages = import.meta.glob<{ default: ImageMetadata }>(
	"/src/assets/pages/about/**/*.{webp,png,jpg,jpeg,svg,gif}",
	{ eager: true }
);

const resolved = image
	? allImages[`/src/assets/pages/about/${image}`]?.default
	: undefined;
const src = resolved || defaultImage;
---

<div class="items-center flex-col text-sm font-medium relative w-full pb-40">
	<div class="relative w-full h-[50em] overflow-hidden">
		<div
			class="items-center bottom-0 justify-center left-0 absolute top-0 flex w-full h-full overflow-hidden rounded-3xl"
		>
			<div
				class="items-center bottom-0 flex-col justify-center left-0 absolute top-0 flex w-full"
			>
				<Image
					src={src}
					alt="About"
					class="bottom-0 left-0 object-cover absolute top-0 align-middle inline-block w-full h-full max-w-full"
				/>
			</div>
		</div>
	</div>
	<div class="mt-16">
		<div class="about-prose max-w-3xl mx-auto">
			<slot />
		</div>
	</div>
</div>

<style>
	.about-prose :global(p) {
		font-size: 1.625rem;
		font-weight: 400;
		line-height: 1.8;
		margin-bottom: 1rem;
	}

	.about-prose :global(ul) {
		list-style: disc;
		padding-left: 1.5rem;
		margin-top: 1rem;
		margin-bottom: 1rem;
	}

	.about-prose :global(li) {
		font-size: 1.375rem;
		font-weight: 400;
		line-height: 1.8;
		margin-bottom: 0.5rem;
	}

	.about-prose :global(h2) {
		font-size: 2rem;
		font-weight: 600;
		line-height: 1.3;
		margin-top: 2rem;
		margin-bottom: 1rem;
	}

	.about-prose :global(h3) {
		font-size: 1.5rem;
		font-weight: 600;
		line-height: 1.3;
		margin-top: 1.5rem;
		margin-bottom: 0.75rem;
	}

	.about-prose :global(strong) {
		font-weight: 600;
	}

	.about-prose :global(em) {
		font-style: italic;
	}
</style>
